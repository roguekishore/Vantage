{
  "manifest_version": 3,
  "name": "VantageCode",
  "version": "1.0",
  "description": "Real-time Vantage progress tracker with auto-sync and account verification.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:8080/*",
    "http://localhost:3000/*",
    "https://api.vantagecode.tech/*",
    "https://judge.vantagecode.tech/*",
    "https://vantagecode.tech/*",
    "https://www.vantagecode.tech/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": ["config.js", "content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://vantagecode.tech/*",
        "https://www.vantagecode.tech/*"
      ],
      "js": ["config.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}